# Database
DATABASE_URL=postgresql://hogar:hogar_dev@db:5432/hogar

# MinIO / S3 Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hogar-uploads
S3_REGION=us-east-1

# Redis
REDIS_URL=redis://localhost:6379

# AI Provider Selection (replicate | openai | anthropic | local)
# Auto-detects based on which API keys are set if not specified
AI_PROVIDER=

# AI Provider: Replicate (ControlNet + SDXL interior design)
REPLICATE_API_TOKEN=r8_your_token_here

# AI Provider: OpenAI (DALL-E 3 for generation, GPT-4o for analysis)
OPENAI_API_KEY=

# AI Provider: Anthropic (Claude for analysis and digitization)
ANTHROPIC_API_KEY=

# AI Provider: Local model (OpenAI-compatible API, e.g. ComfyUI, Automatic1111)
LOCAL_AI_ENDPOINT=http://localhost:7860
LOCAL_AI_MODEL=stable-diffusion
LOCAL_AI_API_KEY=

# AI Analysis: Gemini Vision (floor plan analysis)
GEMINI_API_KEY=your_gemini_key_here

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-random-secret
AUTH_URL=http://localhost:3100
